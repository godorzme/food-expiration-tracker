# DATABASE_URL format: postgresql://user:pass@host:5432/dbname
DATABASE_URL=""
# LINE 推播（選填）：免登入模式下沒有真實的 LINE userId，此管道實質停用，主要提醒走 Web Push。
# 日後加回 LINE Login 後再填此 token 即可啟用 LINE 推播。
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=""
APP_BASE_URL="http://localhost:3000"
# 物件儲存（S3 相容，存照片原圖）。生產環境用 Zeabur Object Storage（MinIO）。
S3_ENDPOINT=""          # 例：http://minio.zeabur.internal:9000（Zeabur 內部）
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_BUCKET="zeabur"
S3_REGION="us-east-1"
S3_FORCE_PATH_STYLE="true"   # MinIO/RustFS 必須 true
S3_PUBLIC_ENDPOINT=""   # 照片看圖用的公開網域（綁在 MinIO 9000 port），presigned URL 以此簽名；本機留空則 fallback S3_ENDPOINT
# 相容用：未設 S3_ENDPOINT 時改走 Cloudflare R2
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="fridge-photos"
# AI Hub
AI_HUB_BASE_URL=""
AI_HUB_API_KEY=""
AI_HUB_VISION_MODEL=""
# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:robynhuang@zuyou.com.tw"
# Session 簽章密鑰（強隨機）— 產生：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=""
# Cron auth
CRON_SECRET=""
